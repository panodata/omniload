# This file is used to set environment variables for the tests.
# If you create a test.env file based on this template then the integration tests will use those env variables automatically.
# Each block gates one source's integration tests in omniload/main_test.py; unset vars cause those tests to skip.

# AppsFlyer
export OMNILOAD_TEST_APPSFLYER_TOKEN="your_appsflyer_token_here"

# Airtable (both required)
export OMNILOAD_TEST_AIRTABLE_TOKEN="your_airtable_token_here"
export OMNILOAD_TEST_AIRTABLE_TABLE="your_airtable_table_id_here"

# Stripe
export OMNILOAD_TEST_STRIPE_TOKEN="your_stripe_token_here"

# Linear
export OMNILOAD_TEST_LINEAR_API_KEY="your_linear_api_key_here"

# Jira (all three required)
export OMNILOAD_TEST_JIRA_BASE_URL="https://your-domain.atlassian.net"
export OMNILOAD_TEST_JIRA_EMAIL="your_jira_email_here"
export OMNILOAD_TEST_JIRA_API_TOKEN="your_jira_api_token_here"

# RevenueCat (API_KEY runs the projects table; PROJECT_ID also needed for customers/products/entitlements/offerings, which skip without it)
export OMNILOAD_TEST_REVENUECAT_API_KEY="your_revenuecat_api_key_here"
export OMNILOAD_TEST_REVENUECAT_PROJECT_ID="your_revenuecat_project_id_here"

# Hostaway
export OMNILOAD_TEST_HOSTAWAY_API_KEY="your_hostaway_api_key_here"

# LinkedIn Ads
export OMNILOAD_TEST_LINKEDIN_ADS_ACCESS_TOKEN="your_linkedin_ads_access_token_here"
